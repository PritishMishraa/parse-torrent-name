{
  "name": "parse-torrent-name",
  "version": "0.5.4",
  "description": "Parses torrent name of a movie or TV show.",
  "type": "commonjs",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "candidate-extractors.js",
    "core.js",
    "index.d.ts",
    "inference.js",
    "index.js",
    "readme.md",
    "resolver.js",
    "tokenizer.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PritishMishraa/parse-torrent-name.git"
  },
  "homepage": "https://github.com/PritishMishraa/parse-torrent-name",
  "bugs": {
    "url": "https://github.com/PritishMishraa/parse-torrent-name/issues"
  },
  "keywords": [
    "torrent",
    "parse torrent name"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "benchmark": "node benchmark/parse.js",
    "lint:package": "npx --yes publint && npx --yes @arethetypeswrong/cli --pack .",
    "prepublishOnly": "npm test && npm run lint:package",
    "test": "node --test"
  }
}
